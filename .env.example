# Copy to `.env` and fill in. `.env` is gitignored — never commit real keys.
# utils.py loads this automatically before any model is downloaded/called.

# HuggingFace — downloads Llama-3.2-3B (gated) and Qwen2.5-14B judge.
# Create one (read scope is enough): https://huggingface.co/settings/tokens
HF_TOKEN=

# External large-LLM upper-bound baseline. Only the provider selected in
# config.yaml -> api_baseline.provider is needed. Leave the other blank.
GEMINI_API_KEY=
# Optional extra Gemini keys from SEPARATE projects. The free tier caps requests
# ~per project/day, so the client rotates across these on 429 (a 30-newsletter
# run needs >20 calls). Add as many as you have: _4, _5, ...
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

ANTHROPIC_API_KEY=
